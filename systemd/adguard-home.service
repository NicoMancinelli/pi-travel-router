[Unit]
Description=AdGuard Home DNS ad-blocker
After=network.target rc-local.service
Wants=rc-local.service

[Service]
Type=simple
ExecStart=/opt/AdGuardHome/AdGuardHome --no-check-update -s run -c /opt/AdGuardHome/AdGuardHome.yaml -w /opt/AdGuardHome
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/opt/AdGuardHome /var/lib/travel-router

[Install]
WantedBy=multi-user.target

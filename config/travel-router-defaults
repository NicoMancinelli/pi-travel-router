# Travel Router configuration
# Install to: /etc/default/travel-router
# Sourced by: router scripts and installer-managed services

# ntfy.sh push notifications
# 1. Pick a unique topic name (treated as a secret — don't share publicly)
# 2. Install ntfy app on iOS/Android: https://ntfy.sh
# 3. Subscribe to your topic in the app
# 4. Set NTFY_TOPIC below — notifications activate immediately
#
# NTFY_TOPIC="travel-router-yourname-2024"
NTFY_TOPIC=""

# iPhone Bluetooth MAC for Bluetooth PAN tethering.
# Pair first with bluetoothctl, then set the phone MAC here.
IPHONE_BT_MAC=""

# Prometheus push gateway endpoint for vnStat metrics.
PUSHGW_URL=""

# Tailscale restore arguments used after captive portal login.
TAILSCALE_UP_ARGS="--advertise-routes=10.3.141.0/24 --accept-dns=false"

# WAN probe targets tried in order by wan-watchdog.sh.
WAN_PING_TARGETS="1.1.1.1 8.8.8.8"

# Optional features. Keep disabled until tested end-to-end on the target Pi.
ENABLE_OPEN_WIFI_FALLBACK="0"
ENABLE_HTTP_UA_REWRITE="0"
ENABLE_TOR_TRANSPARENT="0"
ENABLE_BLOCKLISTS="0"
ENABLE_DOT="0"
ENABLE_VPN_KILLSWITCH="0"
ENABLE_AUTO_UPDATES="0"
ENABLE_AVAHI_REFLECTOR="0"
ENABLE_ADGUARD="0"
ENABLE_AP_SCHEDULE="0"
AP_DISABLE_TIME="02:00"
AP_ENABLE_TIME="07:00"

ENABLE_CLIENT_QOS="0"
AP_CLIENT_BANDWIDTH="unlimited"

ENABLE_PER_DEVICE_VPN="0"
# Space-separated MAC addresses to route through Tailscale (all others go direct)
# Example: VPN_DEVICE_MACS="aa:bb:cc:dd:ee:ff 11:22:33:44:55:66"
VPN_DEVICE_MACS=""

ENABLE_CAKE_AUTOTUNE="0"

# SSH public key for admin access. If set at install time, password auth is
# disabled and only this key is accepted. Set during install or add manually:
# echo '<pubkey>' >> ~/.ssh/authorized_keys
SSH_ADMIN_KEY=""

# Headscale URL — self-hosted Tailscale control server.
# Leave blank to use Tailscale cloud (login.tailscale.com).
# Example: HEADSCALE_URL="http://203.0.113.5:8080"
# Run scripts/setup-headscale.sh on your VPS to get this value.
HEADSCALE_URL=""

ENABLE_BANDWIDTH_DASHBOARD="0"
ENABLE_PROMETHEUS_EXPORTER="0"

# Domain-based split tunnel: route specific domains through Tailscale exit node.
# Enable with ENABLE_SPLIT_TUNNEL=1, then list domains separated by spaces.
# Example: SPLIT_TUNNEL_DOMAINS="mybank.com work.example.com linkedin.com"
ENABLE_SPLIT_TUNNEL="0"
SPLIT_TUNNEL_DOMAINS=""

# Safety cap for update-blocklists.sh on memory-constrained Pi Zero hardware.
MAX_BLOCKLIST_ENTRIES="20000"

# SSH two-factor authentication (TOTP). After enabling:
#   run: sudo -u <user> setup-2fa.sh
ENABLE_2FA="0"

# WAN metric auto-management: re-enforce uplink route metrics on each ifup.
ENABLE_WAN_METRICS="1"

# PiSugar 3 / PiSugar 2 UPS monitoring.
# Enable to check battery every 5 min and shutdown safely when critical.
# Requires a PiSugar HAT connected to GPIO/I2C.
ENABLE_UPS_MONITOR="0"
UPS_SHUTDOWN_THRESHOLD="10"

# Tor AP passphrase (set during install; stored empty here to avoid plaintext).
TOR_AP_PASS=""
